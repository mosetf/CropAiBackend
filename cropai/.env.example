# ============================================================================
# CROPAI BACKEND ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in the values for your environment
# IMPORTANT: Never commit .env to git (it contains secrets!)
# This file shows all available configuration options with examples

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# SECRET_KEY: Django secret key for cryptographic signing
# Generate a new one: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# REQUIRED for production (defaults to dev key if not set)
SECRET_KEY=your-super-secret-key-min-50-characters-for-production

# DEBUG: Set to False in production (default: True for development)
DEBUG=False

# ALLOWED_HOSTS: Comma-separated list of domains allowed to serve
# Development: localhost,127.0.0.1
# Production: example example.com,www.example.com,api.example.com
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# BASE_URL: Root URL for your backend
BASE_URL=http://localhost:8000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database engine: django.db.backends.sqlite3 or django.db.backends.postgresql
# For production, use PostgreSQL: django.db.backends.postgresql
DB_ENGINE=django.db.backends.sqlite3

# For PostgreSQL:
# DB_NAME=cropai_production
# DB_USER=postgres
# DB_PASSWORD=your-secure-db-password
# DB_HOST=db.example.com
# DB_PORT=5432

# For SQLite (default):
DB_NAME=db.sqlite3

# ============================================================================
# WEATHER & EXTERNAL SERVICES
# ============================================================================

# OpenWeather API
OPENWEATHER_FORECAST_URL=https://api.openweathermap.org/data/2.5/forecast
API_KEY=your-openweather-api-key

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allow all CORS origins (only for development)
# Production: set to False and configure CORS_ALLOWED_ORIGINS
CORS_ALLOW_ALL_ORIGINS=True

# Specific CORS allowed origins (comma-separated)
# Example: https://cropai.example.com,https://app.cropai.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================

# JWT token lifetimes (in minutes/days)
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1
JWT_REFRESH_TOKEN_LIFETIME_LONG_DAYS=30

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Email backend: django.core.mail.backends.console.EmailBackend (dev)
# or django.core.mail.backends.smtp.EmailBackend (production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP Configuration (for production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# From address for emails
DEFAULT_FROM_EMAIL=noreply@cropai.app

# ============================================================================
# CACHING CONFIGURATION
# ============================================================================

# Redis URL for production caching
# Development uses local memory cache automatically
# Example: redis://:password@localhost:6379/1
REDIS_URL=redis://127.0.0.1:6379/1

# ============================================================================
# SECURITY SETTINGS (Production)
# ============================================================================

# SSL/HTTPS redirect (production only)
SECURE_SSL_REDIRECT=True

# ============================================================================
# ERROR TRACKING (Optional)
# ============================================================================

# Sentry DSN for error tracking (leave empty to disable)
# Get from: https://sentry.io/
SENTRY_DSN=

# ============================================================================
# DEPLOYMENT GUIDE
# ============================================================================
#
# LOCAL DEVELOPMENT:
#   1. Copy this file: cp .env.example .env
#   2. Leave most values as defaults (DEBUG=True, SQLite, etc.)
#   3. Run: python manage.py runserver
#   4. Uses: settings.py with dev defaults
#
# PRODUCTION DEPLOYMENT:
#   1. Set SECRET_KEY to a strong random value
#   2. Set DEBUG=False
#   3. Set ALLOWED_HOSTS to your domain(s)
#   4. Use PostgreSQL (set DB_ENGINE=django.db.backends.postgresql)
#   5. Set EMAIL configuration for real SMTP
#   6. Set CORS_ALLOW_ALL_ORIGINS=False
#   7. Set CORS_ALLOWED_ORIGINS to your frontend domain(s)
#   8. Configure SSL/HTTPS (SECURE_SSL_REDIRECT=True)
#   9. Set up Redis for caching (REDIS_URL)
#  10. Deploy with: gunicorn core.wsgi -c gunicorn_config.py
#  11. Uses: same settings.py but with env variable overrides
#
# NO SEPARATE SETTINGS FILES NEEDED!
# Everything is controlled via environment variables.
# Same code runs everywhere - only configuration changes.
