# CropAI Backend Environment Variables
# Copy this file to .env.production and fill in values

# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-use-django-secret-generator
ALLOWED_HOSTS=api.cropai.example.com,cropai.example.com

# Database (PostgreSQL recommended for production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=cropai_db
DB_USER=cropai_user
DB_PASSWORD=secure-password-here
DB_HOST=localhost
DB_PORT=5432

# JWT Configuration
JWT_ACCESS_TOKEN_LIFETIME=1800  # 30 minutes in seconds
JWT_REFRESH_TOKEN_LIFETIME=604800  # 7 days in seconds
JWT_ALGORITHM=HS256
JWT_SIGNING_KEY=your-jwt-signing-key

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://cropai.example.com,https://www.cropai.example.com
CORS_ALLOW_CREDENTIALS=True

# Email Configuration (for password reset)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# AWS S3 (optional - for media storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Logging
SENTRY_DSN=  # Optional: for error tracking

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
